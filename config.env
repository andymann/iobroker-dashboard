# ioBroker dashboard configuration
# Edit this file to change the host or add/remove states.
# Changing this file does NOT require rebuilding the Docker image —
# just redeploy the stack in Portainer.
#
# IOBROKER_STATES: one state ID per line (use backslash-n between IDs)
# or comma-separated on one line — both work.

IOBROKER_HOST=http://192.168.178.53:8087
IOBROKER_STATES=zigbee.0.44e2f8fffe61d5d9.state,zigbee.0.44e2f8fffe61d5d9.colortemp,zigbee.0.8c65a3fffef115e2.state,zigbee.0.8c65a3fffef115e2.colortemp,
zigbee.0.001788010c5a5991.state,zigbee.0.001788010c5a5991.color
LISTEN_PORT=8080
FETCH_TIMEOUT=5